{
  "name": "react-color-a11y",
  "version": "0.0.0",
  "description": "React higher-order component to automatically enforce color accessibility",
  "author": "David Lounsbrough",
  "license": "MIT",
  "repository": "Bayer-Group/react-color-a11y",
  "main": "lib/index.js",
  "module": "lib/index.esm.js",
  "types": "lib/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf lib",
    "build": "vite build",
    "build-watch": "vite build --watch",
    "check-release-package": "node ./scripts/check-release-package.mjs",
    "publish-npm": "pnpm clean && pnpm build && pnpm check-release-package && npm publish",
    "start-demo": "pnpm --prefix demo start",
    "build-demo": "pnpm --prefix demo build",
    "lint": "eslint .",
    "test": "pnpm cypress run --component --config-file cypress/config.ts",
    "test-interactive": "pnpm cypress open --config-file cypress/config.ts"
  },
  "keywords": [
    "color",
    "colors",
    "contrast",
    "accessibility",
    "a11y",
    "npm",
    "package",
    "react",
    "typescript"
  ],
  "files": [
    "/lib"
  ],
  "dependencies": {
    "colord": "^2.9.3"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "cypress": "^15.10.0",
    "eslint": "^10.0.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
